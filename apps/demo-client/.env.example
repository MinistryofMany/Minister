# Tessera demo client env.
#
# AUTH_SECRET — used by Auth.js to sign the demo client's own session
# JWT. Has nothing to do with Tessera's OIDC keys. Generate fresh:
#   openssl rand -base64 32
AUTH_SECRET=""

AUTH_URL="http://localhost:3100"
AUTH_TRUST_HOST="true"

# Tessera OIDC settings. In docker-compose dev, the tessera-seed
# service writes these values into the OidcClient table; here we use
# the same values so the OIDC handshake matches up.
TESSERA_ISSUER_URL="http://localhost:3000"
TESSERA_CLIENT_ID="tc_demo"
TESSERA_CLIENT_SECRET="dev-only-demo-client-secret-replace-me"
