{
  "manifest_version": 3,
  "name": "Minister",
  "version": "0.0.0",
  "description": "Performs TLSNotary proofs for the Minister identity wallet.",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://minister.local/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Minister"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
