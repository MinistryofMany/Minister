{
  "manifest_version": 3,
  "name": "Minister",
  "version": "0.0.0",
  "description": "Performs TLSNotary proofs for the Minister identity wallet.",
  "permissions": ["storage", "offscreen"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://minister.local/*",
    "http://localhost:7047/*",
    "ws://localhost:55688/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Minister"
  },
  "cross_origin_embedder_policy": {
    "value": "require-corp"
  },
  "cross_origin_opener_policy": {
    "value": "same-origin"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
