# --- Database --------------------------------------------------------------
# Connection string for the application database. Inside docker-compose this
# points at the postgres service; for local non-docker dev against the
# compose postgres, use localhost:5433 (the compose host mapping).
DATABASE_URL="postgresql://minister:minister@postgres:5432/minister?schema=public"

# --- Auth.js ---------------------------------------------------------------
# Generate with `openssl rand -base64 32`. Must be at least 32 chars.
AUTH_SECRET=""

# URL where the app is reachable to the browser. WebAuthn requires this to
# match the user's origin exactly. Use http://localhost:3000 in local dev;
# WebAuthn works over http on localhost only.
AUTH_URL="http://localhost:3000"

# Required when running behind a reverse proxy (e.g. docker-compose).
AUTH_TRUST_HOST="true"

# --- Minister ---------------------------------------------------------------
# Domain used in the OIDC issuer URL and did:web identifier. Symbolic in
# dev — to publish a real did:web you need DNS + HTTPS on this hostname.
MINISTER_ISSUER_DOMAIN="minister.local"

# Secret used to derive pairwise pseudonymous OIDC `sub` values so different
# relying parties see different ids for the same user. Generate with
# `openssl rand -base64 32`. Optional until Stage 3.
OIDC_PAIRWISE_SECRET=""

# --- Secrets (AWS SSM Parameter Store) -------------------------------------
# When set, at boot the app fetches every SecureString under this path from
# AWS SSM (GetParametersByPath, recursive, decrypted) and injects each as an
# env var named after the last path segment (e.g. /minister/prod/AUTH_SECRET
# -> AUTH_SECRET). Existing (non-empty) env vars always win, so bootstrap +
# non-secret config in this file are never clobbered. Uses the box's static
# AWS creds (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION) as the
# bootstrap identity — Lightsail has no IAM instance roles.
#
# Leave UNSET in dev/local: the loader is then a no-op and secrets come from
# this file / dev key files. In production with this set, a fetch failure or a
# missing required secret (AUTH_SECRET, DATABASE_URL, OIDC_PAIRWISE_SECRET,
# TOKEN_SIGNING_JWK) fails closed — the app refuses to boot.
# MINISTER_SECRETS_SSM_PATH="/minister/prod"

# --- Email ----------------------------------------------------------------
# Mail transport. When both are set, all outbound mail (sign-in magic
# links, plugin verification emails, share-link emails) is sent via
# Resend's HTTP API. Leave unset in dev to print mail to the server log
# instead. In production, leaving these unset makes sendMail throw.
#   RESEND_API_KEY: a Resend API key (send-only is fine).
#   MAIL_FROM:      an address on a domain verified in that Resend
#                   account, e.g. "Minister <noreply@your-domain.com>".
RESEND_API_KEY=""
MAIL_FROM=""

# --- Plugins ---------------------------------------------------------------
# GitHub OAuth plugin. Create an OAuth app at
# https://github.com/settings/developers with the callback URL set to
# http://localhost:3000/badges/new/github/callback. Required only if you
# want to issue oauth-account badges via GitHub.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- TLSNotary -------------------------------------------------------------
# URL of the tlsn-verifier sidecar (Rust HTTP service). Inside
# docker-compose the default below resolves on the compose network.
# For host dev pointing at a compose-managed verifier, use
# http://localhost:7048.
TLSN_VERIFIER_URL="http://tlsn-verifier:7048"

# Comma-separated list of origins (browser extensions, etc.) allowed
# to POST /api/tlsn/submit. Empty/unset = allow any origin (dev). In
# prod, pin to the published extension's chrome-extension://<id>.
TLSN_SUBMIT_ALLOWED_ORIGINS=""
