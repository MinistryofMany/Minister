// Minister — Stage 0 schema.
//
// Combines:
//   * Auth.js (NextAuth v5) required models: User, Account, Session,
//     VerificationToken, Authenticator (for WebAuthn / passkeys).
//   * Minister domain models sketched in CLAUDE.md: Badge, Eligibility,
//     ShareLink, ShareLinkView, OidcClient, OidcAuthorizationCode, AuditLog.
//
// The domain models are defined now (so the initial migration is meaningful)
// but Stage 0 only touches the auth models. Domain tables stay empty until
// Stage 1+ wires features against them.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// ---------------------------------------------------------------------------
// Auth.js models
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  // Denormalized cache of the user's PRIMARY email. NOT the identity key
  // and intentionally NOT @unique — identity is `id` (opaque cuid). The
  // source of truth for which emails a user holds is the UserEmail table
  // (a user can verify many: work, school, personal). Kept here so the
  // Auth.js adapter and existing code that reads `user.email` keep working.
  email         String?
  emailVerified DateTime?
  image         String?

  // Minister profile overrides (user-curated, independent of upstream auth).
  displayName String?
  avatarUrl   String?

  // Monotonic counter embedded in every issued session JWT. Bumping it
  // invalidates all outstanding JWTs for this user on their next
  // protected request — that's how "sign out everywhere" works given
  // we store sessions in JWTs rather than DB rows.
  sessionGeneration Int @default(0)

  // Admin flag gates /admin and the admin server actions. Granted via
  // scripts/make-admin.ts (no self-serve path).
  isAdmin Boolean @default(false)

  // Banned users are treated as signed out by getCurrentSession — the
  // JWT keeps verifying at the Edge, but layer 2 rejects it, same as a
  // sessionGeneration mismatch.
  isBanned Boolean @default(false)

  // Onboarding gate. Null until the forced /welcome setup guide (passkey →
  // Private Identity backup → profile) is finished; the session loader reads it
  // off the row it already loads and bounces an unfinished user to /welcome
  // before any gated page. Stamped once by completeSetup at the final step.
  setupCompletedAt DateTime?

  // Account-merge tombstone. When this user is merged INTO another account
  // it is soft-deleted: `mergedIntoUserId` points at the survivor and the
  // row is retained (with all sessions killed) through the reversal window
  // before hard deletion. getCurrentSession treats a merged user as signed
  // out, same as a ban. See slice 5 (account merge).
  mergedIntoUserId String?
  mergedAt         DateTime?

  // Opaque per-user owner handle for the Sybil-dedup nullifier ledger
  // (crypto-core Phase 1). 16 random bytes base64url, minted LAZILY on the
  // user's first registerDedup and never regenerated (owner-tag stability is
  // what lets the ledger tell `already_yours` from `taken` across re-issues).
  // This mapping stays inside Minister; the Signet backend (Phase 3) sees only
  // the handle, never the userId. Nullable: users with no nullified badge have
  // none yet. See src/lib/nullifier/.
  dedupHandle String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]

  badges               Badge[]
  eligibilities        Eligibility[]
  shareLinks           ShareLink[]
  oidcClients          OidcClient[]
  oidcAccessTokens     OidcAccessToken[]
  oidcGrants           OidcGrant[]
  oidcProfileOverrides OidcProfileOverride[]
  wizardSessions       WizardSession[]
  inviteRedemptions    InviteRedemption[]

  // Slice 1/3/4/5 — multi-credential identity, recovery, and merge.
  userEmails       UserEmail[]
  recoveryCodes    RecoveryCode[]
  recoveryAttempts RecoveryAttempt[]
  subjectOverrides SubjectOverride[]

  // An uploaded avatar image, stored as a Postgres blob in its OWN table so a
  // large photo never bloats the hot User-row reads (session, profile, /u).
  userAvatar UserAvatar?

  // Groups feature (v1). A user can OWN groups (each also gives them an
  // owner-role membership row) and hold memberships in others' groups.
  ownedGroups      Group[]           @relation("GroupOwner")
  groupMemberships GroupMembership[]

  // Anonymous-identity derivation (anon-identity master spec). One enrollment
  // row per user (created lazily at first seed generation, never deleted) plus
  // the PRF-wrapped seed blobs. Ministry holds CIPHERTEXT ONLY — never the seed
  // (governing invariant, spec §2).
  anonSeedEnrollment AnonSeedEnrollment?
  anonSeedBlobs      AnonSeedBlob[]
  // QR device-pairing relay sessions the user's displaying device created.
  anonPairSessions   AnonPairSession[]
}

// A user-uploaded avatar photo, held as a bytea blob. Deliberately a SEPARATE
// table from User: the blob is read only by the public serve route
// (/api/avatars/<publicId>), never on the session/profile hot paths, so it must
// not weigh down a User-row SELECT. Only ever PNG/JPEG/WebP — the upload action
// validates the bytes by magic number and stores the SNIFFED contentType
// (never a client-declared MIME); SVG and everything else are rejected at the
// door (an SVG can carry script → stored XSS). When the user switches back to a
// generated/gravatar/link avatar the row is deleted, so its presence means "this
// user currently uses an uploaded photo".
model UserAvatar {
  userId      String   @id
  // OPAQUE, unguessable public handle the serve route (and the disclosed
  // `picture` claim) key on — NEVER the userId. Serving under the raw userId
  // would leak Minister's global account id to any RP granted the avatar claim
  // and defeat the pairwise `sub`. Random per row, so it reveals nothing.
  publicId    String   @unique
  data        Bytes // bytea; the validated image bytes, stored verbatim (not re-encoded)
  contentType String // the SNIFFED type: "image/png" | "image/jpeg" | "image/webp"
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  // Credential lifecycle (shared shape across credential kinds). A freshly
  // linked account is `quarantined` until the cooldown passes: usable to
  // sign in, but not to mutate other credentials or start recovery/merge.
  label            String?
  status           String    @default("active") // active | quarantined
  quarantinedUntil DateTime?
  lastUsedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model SignInOtp {
  // Short numeric/alphanumeric sign-in code delivered in the same email as
  // the magic link, so a user reading email on their phone can type the code
  // to sign in on another device. Deliberately separate from
  // VerificationToken (whose (identifier, token) is the magic link): a short
  // code needs a hit counter and lockout that the link — a 32-byte,
  // unguessable token — does not.
  //
  // Stored as an HMAC (keyed on AUTH_SECRET), never the plaintext, so a DB
  // read alone can't reveal a live code. Single-use: consumed (deleted) on a
  // correct match. `attempts` drives per-code lockout after N wrong guesses.
  id         String   @id @default(cuid())
  identifier String // the verified email address, lowercased
  codeHash   String // HMAC-SHA256(AUTH_SECRET, normalized code) — never the code itself
  expires    DateTime
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([identifier])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  // Credential lifecycle (shared shape across credential kinds). A freshly
  // enrolled passkey is `quarantined` until the cooldown passes: usable to
  // sign in, but not to mutate other credentials or start recovery/merge.
  label            String?
  status           String    @default("active") // active | quarantined
  quarantinedUntil DateTime?
  addedAt          DateTime  @default(now())
  lastUsedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

// ---------------------------------------------------------------------------
// Minister domain
// ---------------------------------------------------------------------------

model Badge {
  id           String    @id @default(cuid())
  userId       String
  type         String
  // Denormalized non-sensitive attributes for query/display. The signed
  // VC in `vcJwt` is the authoritative artifact.
  attributes   Json
  vcJwt        String
  issuer       String
  issuedAt     DateTime  @default(now())
  expiresAt    DateTime?
  isPublic     Boolean   @default(false)
  sortOrder    Int       @default(0)
  // null = native (issued by Minister). non-null = identifier of the source
  // we imported this VC from.
  importedFrom String?
  pluginId     String?

  // Identity-assurance level of this badge, used to weight it for
  // threshold-based account recovery (slice 4). Higher levels are harder to
  // forge and harder for an attacker to also possess (a passport-backed
  // proof outweighs a Steam login). Set at issuance from the assurance
  // registry; null = unset/lowest. The weight map lives in code so it can
  // be tuned without a migration.
  assuranceLevel String?

  // Optional idempotency key for badges that must not double-mint under
  // concurrent issuance (e.g. the email-domain badge auto-issued on sign-in,
  // where two near-simultaneous logins would otherwise both pass a
  // check-then-insert). The unique constraint makes the second insert fail
  // (P2002) instead of minting a duplicate. NULL for ordinary badges, and
  // Postgres treats each NULL as distinct, so unkeyed badges stay unconstrained.
  dedupeKey String? @unique

  // Opaque handle into the Sybil-dedup nullifier ledger (crypto-core Phase 1).
  // For a badge anchored to a scarce credential (github account id today) this
  // is the ledger entryRef; the raw anchor itself is DISCARDED after
  // nullification and never stored. null = this badge carries no nullifier
  // (invite-code, age/residency placeholders, pre-Phase-1 rows). NOT a foreign
  // key: in Phase 3 the ledger moves into Signet, so this stays a plain opaque
  // string. See src/lib/nullifier/.
  nullifierRef String?

  // Status anchor (revocation, docs/groups-revocation-design.md §5.1). The
  // revocable FACT underneath the badge, NOT the badge row: "gm:<membershipId>"
  // for a group-membership badge, "badge:<badgeId>" for a generic revocable type.
  // null = non-revocable (the common case). Keyed on the fact so a 1-year renewal
  // (new Badge row, same fact) inherits the same per-RP (list, index) handles and
  // a kick still flips the one bit every RP watches. Ministry-internal: it never
  // leaves Minister — what a disclosed VC carries is the per-RP (listId, bitIndex)
  // allocated from it (BadgeStatusEntry), never this anchor.
  statusAnchor String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  // Speeds the dedup-release NOT EXISTS sibling check and collectUserNullifierRefs,
  // and narrows the interim release residual window (see lib/nullifier/interim.ts).
  @@index([nullifierRef])
}

model Eligibility {
  id         String   @id @default(cuid())
  userId     String
  badgeType  String
  eligibleAt DateTime
  // +/- days of fuzz applied at issuance time.
  fuzzDays   Int
  source     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
}

model ShareLink {
  id              String    @id @default(cuid())
  userId          String
  // URL-safe, >= 128 bits entropy.
  token           String    @unique
  badgeIds        String[]
  expiresAt       DateTime
  requiresAccount Boolean   @default(false)
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  views ShareLinkView[]
}

model ShareLinkView {
  id           String   @id @default(cuid())
  shareLinkId  String
  viewerUserId String?
  viewedAt     DateTime @default(now())

  shareLink ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
}

model OidcClient {
  id               String   @id @default(cuid())
  clientId         String   @unique
  // Hashed with Argon2id at rest. Null for public clients (PKCE-only).
  clientSecretHash String?
  name             String
  redirectUris     String[]
  allowedScopes    String[]
  ownerUserId      String?
  // Anonymous-identity namespace (anon-identity master spec §8.1). A lowercase
  // slug (^[a-z0-9-]{3,32}$); null = the client is NOT anon-enabled (no fragment
  // ever delivered). IMMUTABLE once set — the admin update path refuses changes,
  // because rotating it would silently fork every user's identity in that app.
  anonAppId        String?  @unique
  createdAt        DateTime @default(now())

  owner User? @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
}

model OidcAuthorizationCode {
  code                String    @id
  clientId            String
  userId              String
  redirectUri         String
  scopes              String[]
  approvedBadgeIds    String[]
  // Granular profile disclosure. The `profile` scope is split into two
  // independently consentable claims so a user can share their display
  // name without their avatar (or vice versa). When `profile` is not in
  // `scopes` both are false. The resolver emits `name`/`picture` strictly
  // from these flags — never from the `profile` scope alone.
  profileName         Boolean   @default(false)
  profileAvatar       Boolean   @default(false)
  // Granular sybil-score disclosure. Snapshotted at consent; the resolver emits
  // `sybil_bucket` strictly from this flag + bucket, never recomputed at token
  // /userinfo time. sybilScore false whenever `sybil-score` not in scopes.
  sybilScore          Boolean   @default(false)
  sybilBucket         Int?
  // Anonymous-identity epoch, snapshotted at consent from the user's
  // AnonSeedEnrollment.enrollmentEpoch. Echoed as `minister_anon_epoch` on the
  // id_token/userinfo and NEVER recomputed at /token — the client caches its
  // derived branch against it and re-keys only when a later login carries a
  // strictly greater epoch. Null for non-anon clients (no branch is delivered),
  // so the claim is omitted.
  anonEpoch           Int?
  // Required by OIDC Core §3.1.2.1 — echoed back in id_token so RPs can
  // detect replay across user agents.
  nonce               String
  codeChallenge       String
  codeChallengeMethod String
  expiresAt           DateTime
  consumedAt          DateTime?
}

// Issued access tokens — keyed by the random `jti` embedded in the
// access JWT. The JWT itself carries scope + client_id but no raw user
// id; /userinfo resolves userId via lookup on this row. This keeps the
// pairwise pseudonymous `sub` mechanism intact even when RPs decode
// their access tokens.
//
// Separate from OidcAuthorizationCode because the lifetimes differ
// (60s vs 1h) and the lookup keys differ (code vs jti).
model OidcAccessToken {
  jti              String    @id
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId         String
  scopes           String[]
  // Subset of badges the user consented to disclose on the originating
  // /oidc/authorize. Denormalized from the (now-consumed) auth code so
  // /userinfo can return them without that row still existing.
  approvedBadgeIds String[]
  // Granular profile disclosure, denormalized from the auth code so
  // /userinfo emits exactly the name/avatar the user consented to. See
  // OidcAuthorizationCode for the rationale.
  profileName      Boolean   @default(false)
  profileAvatar    Boolean   @default(false)
  // Sybil-score disclosure, denormalized from the auth code (see
  // OidcAuthorizationCode). The token/userinfo path emits `sybil_bucket`
  // strictly from these, never recomputing.
  sybilScore       Boolean   @default(false)
  sybilBucket      Int?
  // Anon-identity epoch, denormalized from the auth code so /userinfo emits the
  // identical `minister_anon_epoch` the id_token carried — never recomputed.
  anonEpoch        Int?
  issuedAt         DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId, clientId])
  @@index([expiresAt])
}

// Durable record of which badge-TYPES and profile sub-claims a user has
// disclosed to a given RP, per (userId, clientId). Survives access-token
// expiry (unlike OidcAccessToken) and is the source of truth for the
// consent screen's "you've already proven these to this platform"
// transparency section.
//
// Carries TYPES only — no VC, no attribute values, no issued-at — so it
// can never be replayed AS a disclosure (the live authorize re-mints fresh
// VC JWTs) and can never satisfy a constrained (`where`/`maxAgeDays`) leaf
// on its own. The grant is a RECORD of disclosure, never an authorization
// to skip consent: every room-join still renders consent, re-discloses a
// live VC, and runs minimizeToPolicy.
//
// `badgeTypes` is monotone-accumulating (union on each consent) — "ever
// proven to this platform". Cleared only when the User is deleted, via the
// cascade (F-4(a): ban / sign-out-all leave the record intact, since it
// reflects true history and revoking tokens already stops access).
model OidcGrant {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId      String
  // Minister badge slugs (TYPES) ever disclosed to this client.
  badgeTypes    String[]
  // Specific badge INSTANCE ids ever disclosed to this client (union-
  // accumulated). Force-included on re-consent so the user can't untick a
  // badge they already proved — but ONLY these specific instances, never
  // every instance of a granted TYPE (audit W1). A since-deleted id simply
  // drops out (loadBadgesForUser scopes to the owning user).
  badgeIds      String[]
  // Whether the curated display name / avatar were ever disclosed to this
  // client. Union-OR accumulated. Drives the transparency display only.
  profileName   Boolean  @default(false)
  profileAvatar Boolean  @default(false)
  // Whether the coarse anti-sybil bucket was ever disclosed to this client.
  // Union-OR accumulated. Drives the consent pre-check default only (mirrors
  // profileName/profileAvatar) — never a substitute for the per-grant snapshot
  // on OidcAuthorizationCode/OidcAccessToken.
  sybilScore    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, clientId])
  @@index([userId])
}

// Admin-created invite codes, redeemed through the invite-code plugin.
// The code string itself never lands in a VC or Badge.attributes — only
// the label does — so a multi-use code can't be recovered from anything
// a holder later discloses.
model InviteCode {
  id    String @id @default(cuid())
  code  String @unique
  // Campaign/cohort name shown to admins and embedded in issued VCs as
  // the `label` claim.
  label String

  // 0 = unlimited. Otherwise usesRemaining is decremented atomically on
  // each redemption and the code stops working at 0.
  usesTotal     Int
  usesRemaining Int

  expiresAt DateTime?
  revokedAt DateTime?
  // Admin who minted the code. SetNull so deleting an admin account
  // doesn't cascade away the audit trail of codes they created.
  createdBy String?
  createdAt DateTime  @default(now())

  redemptions InviteRedemption[]
}

// One row per (code, user). The unique constraint is the double-redeem
// guard — created in the same transaction as the usesRemaining
// decrement, so a constraint violation rolls the decrement back.
model InviteRedemption {
  id           String   @id @default(cuid())
  inviteCodeId String
  userId       String
  redeemedAt   DateTime @default(now())

  inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inviteCodeId, userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// Anonymous-identity enrollment state (anon-identity master spec §6.1, §11.1).
// Holds ONLY metadata — timestamps, status, and a monotonic epoch counter. No
// key material ever (governing invariant §2). One row per user, created lazily
// at first seed generation and NEVER deleted thereafter (user-deletion cascade
// aside); every reset bumps `enrollmentEpoch` and nulls the timestamps.
//
// State encoding: `none` = no row or seedGeneratedAt null; PENDING_BACKUP =
// seedGeneratedAt set + backupConfirmedAt null; ACTIVE = both set.
model AnonSeedEnrollment {
  userId            String    @id
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Monotonic; +1 on every reset. AAD-bound into every PRF-wrapped blob (§7.1),
  // so a stale pre-reset blob fails GCM authentication — the anti-rollback
  // property (I12).
  enrollmentEpoch   Int       @default(1)
  seedGeneratedAt   DateTime?
  backupConfirmedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// A PRF-wrapped root-seed blob (anon-identity master spec §7.1, §11.1). Stores
// AES-256-GCM CIPHERTEXT ONLY, under a KEK derived from a WebAuthn PRF output
// that never leaves the user's browser. A full DB dump yields zero seeds. The
// AAD binding (userId, credentialId, wrapVersion, enrollmentEpoch) lives in the
// ciphertext, not here.
model AnonSeedBlob {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // base64url WebAuthn credential id used for the PRF wrap.
  credentialId String
  // AES-256-GCM(seed) including the 16-byte tag: exactly 32 bytes.
  ciphertext   Bytes
  // Fresh random 12-byte IV per wrap.
  iv           Bytes
  wrapVersion  Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, credentialId])
}

// A QR device-pairing relay session (identity plan, "QR pairing"). Moves the
// 16-byte root from a device that HOLDS it to one that does NOT, over a relay
// Ministry operates but stays cryptographically BLIND to: the server sees the
// sessionId, two IPs, two user-agents, and a 64-byte opaque HPKE blob — never
// the recipient public key (it lives only in the displaying page's memory and
// its screen pixels), never the shared secret, never the root.
//
// C2 (CRITICAL): `userId` is the DISPLAYING device's authenticated account, and
// the seal update is conditioned on `userId = <sealer's own session user>`. That
// same-account check is the SOLE barrier against the remote phish — not defense
// in depth. A sealer authenticated as account B must not be able to deposit into
// account A's session.
//
// TTL 3 minutes, single-use: `sealedPayload` is NULLed in the same statement
// that hands it to the creator (claim).
model AnonPairSession {
  // sessionId: 22-char base64url of 16 random bytes (also carried in the QR).
  id     String @id
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // waiting -> sealed -> claimed; expired is terminal. String, not an enum, to
  // match the codebase's other lifecycle columns and keep migrations trivial.
  state         String  @default("waiting")
  // 86-char base64url HPKE relay body (enc || ct). NULLed on claim (single-use).
  sealedPayload String?
  // SHA-256 (hex) of the creatorSecret the displaying device holds; the claim
  // capability. The secret itself is never stored.
  creatorSecretHash String
  expiresAt         DateTime
  // Connection facts the relay observed, shown to the SCANNER so it can judge
  // "is this my other device?". Country/city are best-effort (Cloudflare geo
  // headers; city needs a managed transform and may be absent).
  creatorIp      String?
  creatorUa      String?
  creatorCountry String?
  creatorCity    String?
  sealerIp       String?
  sealerUa       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

// Per-user, per-plugin wizard run. Persists across requests (and email
// magic-link round-trips) without depending on cookies. Cleaned up when
// completed or when expiresAt passes.
model WizardSession {
  id           String    @id @default(cuid())
  userId       String
  pluginId     String
  state        Json
  // When the current step is a `magic-link`, this is the random token
  // embedded in the email URL. Unique so a link can be resolved back to
  // its wizard session.
  pendingToken String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, pluginId])
}

// ---------------------------------------------------------------------------
// Multi-credential identity, recovery, and merge (slices 1–5)
// ---------------------------------------------------------------------------

// One verified (or pending) email address belonging to a user. Replaces
// User.email as the identity-bearing email store: a user can hold many
// (work, school, personal), any can receive a sign-in magic link, exactly
// one is `isPrimary` (notifications). `email` is globally @unique — an
// address belongs to at most one account. App logic enforces the
// single-primary-per-user invariant inside the same transaction that flips
// it (Postgres can't express a portable partial-unique here).
model UserEmail {
  id               String    @id @default(cuid())
  userId           String
  email            String    @unique
  verifiedAt       DateTime?
  isPrimary        Boolean   @default(false)
  // Lifecycle. A freshly added email is `quarantined` until the cooldown
  // passes: it can receive magic links but can't be used to mutate other
  // credentials or start recovery/merge (blast-radius bound for a
  // compromised inbox that adds itself).
  status           String    @default("active") // active | quarantined
  quarantinedUntil DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Single-use account-recovery codes. The plaintext is shown once at
// generation; only the Argon2id hash is stored (same hashing as
// OidcClient.clientSecretHash). Regenerating deletes all unused rows for
// the user. Redeeming one lands a reduced-assurance, quarantined session.
model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// An in-flight threshold-recovery session (slice 4). The user re-proves a
// set of badges live; each accepted proof adds its assurance weight until
// `accumulatedScore >= requiredScore`. `nonce` is bound into every live
// re-proof so a stored/leaked VC can't be replayed — recovery requires
// FRESH proofs against this attempt. Satisfying it lands a quarantined,
// reduced-assurance session, never a full takeover.
model RecoveryAttempt {
  id               String    @id @default(cuid())
  userId           String
  nonce            String    @unique
  status           String    @default("pending") // pending | satisfied | consumed | expired | failed
  requiredScore    Int
  accumulatedScore Int       @default(0)
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  satisfiedAt      DateTime?
  consumedAt       DateTime?

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  proofs RecoveryProof[]

  @@index([userId, status])
}

// One accepted live re-proof contributing weight to a RecoveryAttempt. The
// (attemptId, badgeType) pair is unique so the same badge type can't be
// re-proven twice to double-count toward the threshold.
model RecoveryProof {
  id        String   @id @default(cuid())
  attemptId String
  badgeType String
  weight    Int
  provedAt  DateTime @default(now())

  attempt RecoveryAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, badgeType])
  @@index([attemptId])
}

// The merge seam (slice 5). `pairwiseSub(userId, clientId)` consults this
// table BEFORE deriving: if a row exists, that sub is returned; otherwise
// it falls back to the HMAC derivation. Empty by default (zero behaviour
// change). Account merge populates it on the survivor so the survivor can
// keep presenting a donor's historical pairwise identity to every RP the
// donor used — lossless for RPs only one account touched.
model SubjectOverride {
  userId   String
  clientId String
  sub      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
  @@index([userId])
}

// Per-relying-party profile persona ("snapshot per app"). At first consent
// the user may override the display name / avatar disclosed to a specific RP;
// the value is snapshotted here and stays FIXED for that app even if the user
// later edits their global default (User.displayName / User.avatarUrl). The
// OIDC disclosure path (oidc-claims.ts:resolveUserClaims) reads this per-RP
// override first, per field, and falls back to the global curated value only
// when the override row is absent or that field is null. Editing happens later
// on /settings/apps. The upstream auth identity (User.name / User.image) is
// still NEVER a source here — same invariant as the global curated fields.
//
// `clientId` is the OidcClient.clientId string, the same key OidcGrant and
// OidcAccessToken use. Mirrors SubjectOverride's (userId, clientId) shape.
model OidcProfileOverride {
  userId      String
  clientId    String
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
  @@index([userId])
}

// Audit + reversal record for an account merge. Standalone (stores ids, no
// FK) so a hard-deleted donor doesn't cascade the record away. `snapshot`
// holds enough (moved rows, collision resolutions, overrides created) to
// reverse the merge until `reversibleUntil`.
model MergeRecord {
  id              String    @id @default(cuid())
  survivorUserId  String
  donorUserId     String
  snapshot        Json
  createdAt       DateTime  @default(now())
  reversibleUntil DateTime
  reversedAt      DateTime?

  @@index([survivorUserId])
  @@index([donorUserId])
}

// Sybil-dedup nullifier ledger — INTERIM backend (crypto-core Phase 1).
//
// Enforces one-credential-one-account at issuance: `value` is a deterministic
// keyed HMAC of (anchor, badgeType), UNIQUE-indexed, so two accounts proving
// the same scarce credential collide on insert. The raw anchor is NEVER stored
// (only its HMAC), and `ownerHandle` is the opaque per-user handle, never a
// userId.
//
// INTERIM-WINDOW DEVIATION (Phases 1-3, users==0 guarded): this table lives in
// Minister's Postgres with the deriving key (k_int, from OIDC_PAIRWISE_SECRET)
// co-resident in env/SSM — exactly the exfil/dictionary-oracle the ADR moved
// the real ledger into Signet to avoid. Accepted only because prod has zero
// users; the ledger moves into Signet in Phase 3 and this table is DROPPED in
// Phase 8. See build plan §2.2 and the ADR "Interim-window deviation" note.
model NullifierEntry {
  id          String   @id @default(cuid())
  // Deterministic HMAC output. Bytes (not string) so equality is exact byte
  // comparison with no encoding ambiguity. UNIQUE is the dedup comparison.
  value       Bytes    @unique
  // Opaque per-user handle (User.dedupHandle), NOT a userId.
  ownerHandle String
  badgeType   String
  createdAt   DateTime @default(now())

  @@index([ownerHandle])
}

// SALTED stage-2 drift-detection cache (crypto-core Phase 4 / build-plan §2.1).
// Minister trusts Signet for the CORRECTNESS of the per-RP disclosed nullifier
// (stage 2 carries no DLEQ). To catch a Signet that silently DRIFTS the value
// for the same credential (ban-evasion), Minister keeps one row per
// (entryRef, clientId) and, on every disclosure, recomputes SHA-256(salt||N_rp)
// and compares it to `check`; a mismatch fails closed (the badge is omitted +
// alerted). New (entryRef, clientId) → a row is inserted.
//
// The per-row RANDOM `salt` is the whole point: it makes `check` carry NO
// cross-row equality structure and no dictionary surface, so this cache does
// NOT reintroduce the M1 equality oracle the ledger was moved to Signet to
// avoid — same-row comparison is all drift detection needs. Additive and
// nullable-safe: absent rows just mean "first disclosure, nothing to compare".
model NullifierRpCheck {
  id        String   @id @default(cuid())
  // Opaque ledger handle (Badge.nullifierRef) — no equality structure.
  entryRef  String
  clientId  String
  // 16 random bytes, minted per row. The de-correlating salt (see model doc).
  salt      Bytes
  // SHA-256(salt || utf8(N_rp)). The only value compared, and only ever against
  // this same row's recomputation — never across rows.
  check     Bytes
  createdAt DateTime @default(now())

  @@unique([entryRef, clientId])
}

// Anti-sybil / recovery weight config (design spec §3, phase-1 impl brief §1).
// One row per (badgeType, qualifier). Carries TWO operator-editable weights for
// two threat models that must never be conflated: `sybilWeight` (cost to farm a
// fake human, feeds only the RP-facing score) and `recoveryWeight` (contribution
// to the account-recovery threshold, migrated from assurance.ts). Category
// membership is FK-by-name to SybilCategory (validated in app, not a DB FK).
model BadgeWeight {
  badgeType             String
  qualifier             String // "*" or a resolved qualifier token (e.g. "github", "github:24")
  sybilWeight           Int
  recoveryWeight        Int // live/effective recovery contribution
  category              String // FK-by-name to SybilCategory.name (validated in app, not DB FK)
  allowSoloRecovery     Boolean   @default(false)
  // Delayed-apply for RECOVERY weakening only (weight INCREASE). null = no pending change.
  pendingRecoveryWeight Int?
  recoveryEffectiveAt   DateTime?
  updatedAt             DateTime  @updatedAt

  @@id([badgeType, qualifier])
  @@index([category])
}

// Operator-editable sybil category with a per-category cap. Membership lives on
// each BadgeWeight row's `category` column; this table holds just name + cap.
model SybilCategory {
  name String @id
  cap  Int
}

// Singleton (single row, id = "singleton"). Four raw-score cutoffs + two
// qualifying-category breadth floors that gate buckets 3 and 4.
model SybilBucketConfig {
  id             String   @id @default("singleton")
  // raw-score cutoffs
  bucket1Raw     Int // >= this -> at least bucket 1
  bucket2Raw     Int
  bucket3Raw     Int
  bucket4Raw     Int
  // qualifying-category breadth floors
  bucket3MinCats Int
  bucket4MinCats Int
  updatedAt      DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Groups feature (v1) — see docs/groups-design.md.
//
// Belonging to a group is expressed as a revocable `group-membership` badge, so
// it rides the existing badge + disclosure + policy-gating machinery. The
// GroupMembership row is the SOURCE OF TRUTH: the OIDC disclosure path re-checks
// the live row before re-minting a group badge (no row -> omitted; role changed
// -> re-minted with the new role), which is how removal/role-change take effect.
// ---------------------------------------------------------------------------

model Group {
  id          String  @id @default(cuid())
  // Canonical [a-z0-9] (internal hyphens) slug — the `group` badge claim RPs
  // gate on. Immutable in v1 (renaming it would strand every issued badge's
  // claim and gate); the human-facing name is `displayName`.
  slug        String  @unique
  displayName String
  description String?
  ownerUserId String
  owner       User    @relation("GroupOwner", fields: [ownerUserId], references: [id])
  // false => rendered as an UNVERIFIED group (free founding). true is set only
  // out-of-band (admin grant now; a paid/org-proof flow later).
  verified    Boolean @default(false)

  createdAt   DateTime          @default(now())
  memberships GroupMembership[]

  @@index([ownerUserId])
}

// Slug tombstone (W5). A group slug is the RP gating key (rooms gate on
// `where: { group: "acme" }`), so deleting a group and immediately re-founding the
// same slug would let the NEW group's members satisfy a gate meant for the old
// group. deleteGroup writes a tombstone; createGroup refuses to re-found a slug
// tombstoned within SLUG_TOMBSTONE_DAYS, giving RP status lists + entitlement
// sweeps time to propagate the old group's revocations before the name is reusable.
model GroupSlugTombstone {
  slug      String   @id
  deletedAt DateTime @default(now())
}

model GroupMembership {
  id       String  @id @default(cuid())
  groupId  String
  group    Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String // "owner" | "admin" | "member"
  // Opt-in to the (v2, deferred) public directory; default private.
  isPublic Boolean @default(false)
  // Acting admin/owner userId that added this member, for audit.
  addedBy  String?

  createdAt DateTime @default(now())

  // revocation: status-list seam. Removal is authoritative at MINT time — the
  // disclosure path (oidc-claims.loadApprovedBadgeJwts) re-checks this row and
  // omits/updates the badge before re-minting. Invalidating a VC a relying party
  // ALREADY holds mid-lifetime is a separate credential-status upgrade (a W3C
  // Bitstring StatusList2021 that would benefit every revocable badge), planned
  // as a cross-badge follow-up; a per-membership status index would attach here.

  @@unique([groupId, userId])
  @@index([userId])
}

// Singleton (id = "singleton"). Tunable knobs for the group founding gate, kept
// out of the action so an operator can adjust them without a deploy (mirrors the
// sybil/recovery config singletons; seeded by scripts/seed-sybil-config.ts).
model GroupConfig {
  id                String   @id @default("singleton")
  // Minimum anti-sybil bucket (0-4) required to FOUND a group. Seed 2.
  foundingMinBucket Int
  // Max groups a single user may own before founding is blocked. Seed 3; later
  // tiers raise this.
  maxOwnedGroups    Int
  updatedAt         DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Badge revocation — per-RP Bitstring Status Lists (docs/groups-revocation-design.md).
// A disclosed revocable badge carries a `credentialStatus` pointing at (its RP's
// list, a randomly-assigned bit index). Ministry publishes each list as a
// short-lived, #key-2-signed W3C BitstringStatusListCredential; kicking a member
// flips one bit. Per-RP partitioning + per-RP random indices mean nothing is
// joinable across RPs (§5.2/§5.3).
// ---------------------------------------------------------------------------

// One sharded bitstring for one relying party. `id` is the PUBLIC listId — an
// opaque cuid served at /status/<id>, NOT derived from clientId (no
// offline-guessable mapping if a secret leaks). Fixed 8,192-bit (1 KiB) shards
// (§5.3): the KMS #key-2 RAW-sign ceiling is 4,096 bytes and a 16 Kib shard busts
// it in the incompressible worst case. `bits` is the raw bitstring; `signedJwt`
// is the latest pre-signed credential the GET route serves verbatim (hot path
// does zero crypto). `version` is monotonic, bumped on EVERY republication
// (content OR heartbeat) — the SDK's rollback high-water mark.
model StatusList {
  id          String   @id @default(cuid())
  clientId    String
  shardNo     Int
  sizeBits    Int      @default(8192)
  version     Int      @default(0)
  bits        Bytes
  // Empty ("") until the publisher first signs this shard. The GET route serves
  // 503 for an unpublished shard; the SDK then fails open on last-known state.
  signedJwt   String   @default("")
  publishedAt DateTime @default(now())

  @@unique([clientId, shardNo])
}

// The per-(fact, RP) revocation handle. `statusAnchor` is the Badge.statusAnchor
// (the fact); (listId, bitIndex) is what the disclosed VC's credentialStatus
// points at. Allocated LAZILY at first disclosure of the revocable badge to this
// RP, with a crypto-random index (§5.2). Two @@unique invariants carry the
// security properties: one handle per (fact, RP), and no index is EVER reused.
model BadgeStatusEntry {
  id           String    @id @default(cuid())
  statusAnchor String
  clientId     String
  listId       String
  bitIndex     Int
  // Set => this fact is revoked and the bit must be published as 1. Monotonic:
  // `revocation` status is irreversible by spec, so this is never cleared.
  revokedAt    DateTime?
  // Per-(event, list) jitter floor (§5.7): the publisher folds a revoked entry's
  // bit only once `revealAfter <= now`, decorrelating one kick's publication
  // instant across RPs. Drawn independently per row from a CSPRNG at revoke time.
  revealAfter  DateTime?
  createdAt    DateTime  @default(now())

  @@unique([statusAnchor, clientId])
  @@unique([listId, bitIndex])
  // The publisher scans revoked-but-eligible entries by list.
  @@index([listId, revokedAt])
}

// Durable per-ANCHOR revocation tombstone (W1). Keyed on the fact (statusAnchor),
// written by revokeStatusAnchor INDEPENDENTLY of whether any per-RP
// BadgeStatusEntry existed at revoke time. This closes the post-revoke allocation
// race: a member kicked before ever disclosing to an RP (no entry to flip) — or a
// disclosure in flight while the kick commits — would otherwise allocate a FRESH
// entry whose bit nobody sets, a permanently un-revocable handle. allocateStatusEntry
// consults this row and is born-revoked (revokedAt = revealAfter = now) for an
// already-revoked anchor. Never deleted (a re-add makes a NEW anchor, §5.1).
model StatusAnchorRevocation {
  statusAnchor String   @id
  revokedAt    DateTime @default(now())
  reason       String
  createdAt    DateTime @default(now())
}

// Singleton (id = "singleton"). Recovery threshold with delayed-apply. The live
// read honors `pendingThreshold`/`thresholdEffectiveAt` (a threshold DECREASE is
// a weakening and takes effect only after the delay window).
model RecoveryConfig {
  id                   String    @id @default("singleton")
  threshold            Int // live/effective (seed 100; bounds [100,1000])
  pendingThreshold     Int? // delayed weakening (threshold DECREASE)
  thresholdEffectiveAt DateTime?
  updatedAt            DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Badge statistics (anti-sybil phase 2, §1). Materialized by the recompute job
// (`stats-recompute.ts`); the admin + public transparency pages read these rows
// rather than running heavy cross-badge COUNT(DISTINCT userId) per request. All
// counts are DISTINCT NATIVE, UNEXPIRED holders (issuer = Minister's own DID).
// ---------------------------------------------------------------------------

// Per badge type: the type-level total (attributeKey = attributeValue = "") plus,
// for each ALLOWLISTED (key, value), the distinct-holder count. The allowlist
// (stats-allowlist.ts) is closed-enum only — no PII key (email/domain/handle/…)
// is ever materialized here.
model BadgeStat {
  id             String   @id @default(cuid())
  badgeType      String
  attributeKey   String // "" for the type-level total; else an ALLOWLISTED key
  attributeValue String // "" for the type-level total; else the enum value
  count          Int // distinct-user count
  computedAt     DateTime

  @@unique([badgeType, attributeKey, attributeValue])
  @@index([badgeType])
}

// Operator-defined conditional cohort: numerator/denominator each a CohortFilter
// (cohort-filter.ts), allowlist-validated. e.g. "aged github accounts as a
// fraction of github accounts".
model CohortStatDef {
  id                String      @id @default(cuid())
  label             String
  numeratorFilter   Json // CohortFilter, allowlist-validated
  denominatorFilter Json
  // A cohort is NOT public until an admin explicitly publishes it. The public
  // /transparency page renders only published defs; the label + counts are then
  // world-visible.
  published         Boolean     @default(false)
  createdAt         DateTime    @default(now())
  stat              CohortStat?
}

model CohortStat {
  defId       String        @id
  def         CohortStatDef @relation(fields: [defId], references: [id], onDelete: Cascade)
  numerator   Int
  denominator Int
  computedAt  DateTime
}

// One row per bucket 0-4: how many distinct users currently score that bucket.
model BucketStat {
  bucket     Int      @id // 0-4
  count      Int // distinct users currently scoring this bucket
  computedAt DateTime
}

// Singleton, tracks the last full recompute for freshness + "as of" display.
model StatsRun {
  id         String   @id @default("singleton")
  computedAt DateTime
  durationMs Int
}
