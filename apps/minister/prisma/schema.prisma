// Minister — Stage 0 schema.
//
// Combines:
//   * Auth.js (NextAuth v5) required models: User, Account, Session,
//     VerificationToken, Authenticator (for WebAuthn / passkeys).
//   * Minister domain models sketched in CLAUDE.md: Badge, Eligibility,
//     ShareLink, ShareLinkView, OidcClient, OidcAuthorizationCode, AuditLog.
//
// The domain models are defined now (so the initial migration is meaningful)
// but Stage 0 only touches the auth models. Domain tables stay empty until
// Stage 1+ wires features against them.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// ---------------------------------------------------------------------------
// Auth.js models
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Minister profile overrides (user-curated, independent of upstream auth).
  displayName String?
  avatarUrl   String?

  // Monotonic counter embedded in every issued session JWT. Bumping it
  // invalidates all outstanding JWTs for this user on their next
  // protected request — that's how "sign out everywhere" works given
  // we store sessions in JWTs rather than DB rows.
  sessionGeneration Int @default(0)

  // Admin flag gates /admin and the admin server actions. Granted via
  // scripts/make-admin.ts (no self-serve path).
  isAdmin Boolean @default(false)

  // Banned users are treated as signed out by getCurrentSession — the
  // JWT keeps verifying at the Edge, but layer 2 rejects it, same as a
  // sessionGeneration mismatch.
  isBanned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]

  badges            Badge[]
  eligibilities     Eligibility[]
  shareLinks        ShareLink[]
  oidcClients       OidcClient[]
  oidcAccessTokens  OidcAccessToken[]
  wizardSessions    WizardSession[]
  inviteRedemptions InviteRedemption[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

// ---------------------------------------------------------------------------
// Minister domain
// ---------------------------------------------------------------------------

model Badge {
  id        String @id @default(cuid())
  userId    String
  type      String
  // Denormalized non-sensitive attributes for query/display. The signed
  // VC in `vcJwt` is the authoritative artifact.
  attributes Json
  vcJwt      String
  issuer     String
  issuedAt   DateTime  @default(now())
  expiresAt  DateTime?
  isPublic   Boolean   @default(false)
  sortOrder  Int       @default(0)
  // null = native (issued by Minister). non-null = identifier of the source
  // we imported this VC from.
  importedFrom String?
  pluginId     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model Eligibility {
  id         String   @id @default(cuid())
  userId     String
  badgeType  String
  eligibleAt DateTime
  // +/- days of fuzz applied at issuance time.
  fuzzDays Int
  source   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
}

model ShareLink {
  id              String    @id @default(cuid())
  userId          String
  // URL-safe, >= 128 bits entropy.
  token           String    @unique
  badgeIds        String[]
  expiresAt       DateTime
  requiresAccount Boolean   @default(false)
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  views ShareLinkView[]
}

model ShareLinkView {
  id           String   @id @default(cuid())
  shareLinkId  String
  viewerUserId String?
  viewedAt     DateTime @default(now())

  shareLink ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
}

model OidcClient {
  id               String   @id @default(cuid())
  clientId         String   @unique
  // Hashed with Argon2id at rest. Null for public clients (PKCE-only).
  clientSecretHash String?
  name             String
  redirectUris     String[]
  allowedScopes    String[]
  ownerUserId      String?
  createdAt        DateTime @default(now())

  owner User? @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
}

model OidcAuthorizationCode {
  code                String    @id
  clientId            String
  userId              String
  redirectUri         String
  scopes              String[]
  approvedBadgeIds    String[]
  // Granular profile disclosure. The `profile` scope is split into two
  // independently consentable claims so a user can share their display
  // name without their avatar (or vice versa). When `profile` is not in
  // `scopes` both are false. The resolver emits `name`/`picture` strictly
  // from these flags — never from the `profile` scope alone.
  profileName         Boolean   @default(false)
  profileAvatar       Boolean   @default(false)
  // Required by OIDC Core §3.1.2.1 — echoed back in id_token so RPs can
  // detect replay across user agents.
  nonce               String
  codeChallenge       String
  codeChallengeMethod String
  expiresAt           DateTime
  consumedAt          DateTime?
}

// Issued access tokens — keyed by the random `jti` embedded in the
// access JWT. The JWT itself carries scope + client_id but no raw user
// id; /userinfo resolves userId via lookup on this row. This keeps the
// pairwise pseudonymous `sub` mechanism intact even when RPs decode
// their access tokens.
//
// Separate from OidcAuthorizationCode because the lifetimes differ
// (60s vs 1h) and the lookup keys differ (code vs jti).
model OidcAccessToken {
  jti              String    @id
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId         String
  scopes           String[]
  // Subset of badges the user consented to disclose on the originating
  // /oidc/authorize. Denormalized from the (now-consumed) auth code so
  // /userinfo can return them without that row still existing.
  approvedBadgeIds String[]
  // Granular profile disclosure, denormalized from the auth code so
  // /userinfo emits exactly the name/avatar the user consented to. See
  // OidcAuthorizationCode for the rationale.
  profileName      Boolean   @default(false)
  profileAvatar    Boolean   @default(false)
  issuedAt         DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId, clientId])
  @@index([expiresAt])
}

// Admin-created invite codes, redeemed through the invite-code plugin.
// The code string itself never lands in a VC or Badge.attributes — only
// the label does — so a multi-use code can't be recovered from anything
// a holder later discloses.
model InviteCode {
  id    String @id @default(cuid())
  code  String @unique
  // Campaign/cohort name shown to admins and embedded in issued VCs as
  // the `label` claim.
  label String

  // 0 = unlimited. Otherwise usesRemaining is decremented atomically on
  // each redemption and the code stops working at 0.
  usesTotal     Int
  usesRemaining Int

  expiresAt DateTime?
  revokedAt DateTime?
  // Admin who minted the code. SetNull so deleting an admin account
  // doesn't cascade away the audit trail of codes they created.
  createdBy String?
  createdAt DateTime  @default(now())

  redemptions InviteRedemption[]
}

// One row per (code, user). The unique constraint is the double-redeem
// guard — created in the same transaction as the usesRemaining
// decrement, so a constraint violation rolls the decrement back.
model InviteRedemption {
  id           String   @id @default(cuid())
  inviteCodeId String
  userId       String
  redeemedAt   DateTime @default(now())

  inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inviteCodeId, userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// Per-user, per-plugin wizard run. Persists across requests (and email
// magic-link round-trips) without depending on cookies. Cleaned up when
// completed or when expiresAt passes.
model WizardSession {
  id           String    @id @default(cuid())
  userId       String
  pluginId     String
  state        Json
  // When the current step is a `magic-link`, this is the random token
  // embedded in the email URL. Unique so a link can be resolved back to
  // its wizard session.
  pendingToken String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, pluginId])
}
