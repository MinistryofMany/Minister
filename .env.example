# Compose-level env. Copy to `.env` and fill in.
# These flow through docker-compose.yml into the tessera service.

# Generate with: openssl rand -base64 32
# Must be at least 32 chars. Auth.js refuses to start without a value.
AUTH_SECRET=

# Issuer domain used in did:web and OIDC `iss`. tessera.local is symbolic
# in dev — to publish a real did:web you need DNS + HTTPS on this host.
TESSERA_ISSUER_DOMAIN=tessera.local

# Generate with: openssl rand -base64 32
# Used to derive pairwise pseudonymous OIDC `sub` values (different RPs
# see different ids for the same user). Optional until Stage 3.
OIDC_PAIRWISE_SECRET=
